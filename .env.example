# Public base URL of the deployed site (no trailing slash). Used for canonical
# URLs, Open Graph, the sitemap, robots.txt, and JSON-LD.
# FLAG: set the real domain in the Vercel project settings before launch.
NEXT_PUBLIC_SITE_URL=https://zegwastudio.com

# GA4 Measurement ID (format G-XXXXXXXXXX), from the GA4 property's Data
# Streams settings. Consent Mode v2 gates it: unset, no gtag script loads at
# all; set, it loads with analytics_storage denied by default until a visitor
# accepts the cookie banner. See lib/analytics.ts and app/layout.tsx.
NEXT_PUBLIC_GA_ID=

# POST endpoint for the "Get free audit" form (components/AuditForm.tsx).
# Unset means every submission fails closed (the form shows its error state
# rather than pretending to work).
NEXT_PUBLIC_AUDIT_ENDPOINT=

# POST endpoint for the contact form (components/ContactForm.tsx). Point this
# at a Google Apps Script Web App deployment bound to a Sheet -- it appends a
# row per submission and emails Gwatsin. Unset means every submission fails
# closed, same as NEXT_PUBLIC_AUDIT_ENDPOINT above.
NEXT_PUBLIC_CONTACT_ENDPOINT=
